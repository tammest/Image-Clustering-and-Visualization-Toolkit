def ordered_present(labels, desired):
    s = set(labels)
    return [x for x in desired if x in s]

def crosstab_counts(df, left_col, right_col, left_order=None, right_order=None):
    ct = pd.crosstab(df[left_col], df[right_col]).astype(int)
    if right_order is not None:
        ct = ct.reindex(columns=right_order, fill_value=0)
    if left_order is not None:
        ct = ct.reindex(index=left_order, fill_value=0)
    return ct

def plot_chord_from_counts(
    ct, title, outfile, space=5,
    left_palette=None,          # dict: left labels -> color (cohorts)
    right_palette=None,         # dict: right labels -> color (bins)
    legend_bins_labels=None,
    legend_bins_palette=None,
    legend_ncol=5,
    hide_right_labels=False,    # set True to hide bin labels on the ring
):
    from pycirclize import Circos
    import matplotlib.patches as mpatches

    # --- Build square adjacency with symmetric weights (one undirected ribbon) ---
    left_labels  = list(ct.index)
    right_labels = list(ct.columns)
    labels = left_labels + right_labels

    M = pd.DataFrame(0.0, index=labels, columns=labels)
    M.loc[left_labels,  right_labels] = ct.values
    M.loc[right_labels, left_labels]  = ct.values.T   # keep symmetric to avoid zero sectors

    # Early exit if everything is zero
    if M.values.sum() == 0:
        print("[Skip] All-zero matrix for chord diagram.")
        return

    # Drop sectors with no connections
    deg = M.sum(axis=1)
    nz = deg > 0
    M = M.loc[nz, nz]
    left_labels  = [l for l in left_labels  if l in M.index]
    right_labels = [r for r in right_labels if r in M.index]

    # --- Sector colors: cohorts (left) and bins (right) keep their palettes ---
    sector_colors = {}
    if left_palette:
        for l in left_labels:
            sector_colors[l] = left_palette.get(l, "#888888")
    if right_palette:
        for r in right_labels:
            sector_colors[r] = right_palette.get(r, "#BBBBBB")

    # --- Link styling: color each ribbon by the BIN (right) wedge color ---
    def link_kws_handler(src, dst, value):
        # Determine the bin side of the pair, then use its color
        if dst in right_labels and right_palette and dst in right_palette:
            col = right_palette[dst]
        elif src in right_labels and right_palette and src in right_palette:
            col = right_palette[src]
        else:
            col = "#999999"
        return dict(fc=col, ec=col, lw=0.6, alpha=0.9)

    circos = Circos.chord_diagram(
        M,
        space=space,
        cmap=sector_colors,                     # sector colors
        label_kws=dict(size=9),
        link_kws=dict(),                        # base defaults
        link_kws_handler=link_kws_handler,      # per-link color = bin color
    )
    fig = circos.plotfig(figsize=(8, 8))
    plt.title(title)

    # Optionally hide right labels for a cleaner look
    if hide_right_labels and fig.axes:
        ax = fig.axes[0]
        for txt in list(ax.texts):
            if txt.get_text() in right_labels:
                txt.set_visible(False)

    # Bin legend (uses your intended bin colors)
    if legend_bins_labels and legend_bins_palette:
        handles = [
            mpatches.Patch(facecolor=legend_bins_palette[lab], edgecolor="none", label=lab)
            for lab in legend_bins_labels if lab in legend_bins_palette
        ]
        fig.legend(
            handles=handles,
            loc="lower center",
            ncol=legend_ncol,
            frameon=False,
            bbox_to_anchor=(0.5, -0.02),
        )
        fig.subplots_adjust(bottom=0.12)

    fig.savefig(outfile, dpi=300, bbox_inches="tight")
    plt.close(fig)
    print(f"Saved chord: {outfile}")

if PYCIRCLIZE_AVAILABLE:
