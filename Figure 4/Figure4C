def find_main_array(zroot):
    """Return the main image array."""
    import zarr as _zarr
    if isinstance(zroot, _zarr.Array):
        return zroot
    candidates = []
    def walk(g, prefix=""):
        for k, v in g.items():
            if isinstance(v, _zarr.Array):
                candidates.append((prefix + k, v))
            elif isinstance(v, _zarr.Group):
                walk(v, prefix + k + "/")
    walk(zroot)
    if not candidates:
        raise RuntimeError("No arrays found in data.zarr group")
    _, best_arr = max(candidates, key=lambda kv: np.prod(kv[1].shape))
    return best_arr

def load_positions_hw(root_path, sample_name, tile_size):
    """Load positions CSV where h=Y, w=X in pixel coords."""
    path = os.path.join(root_path, sample_name, f"tiles/positions_{tile_size}.csv")
    df = pd.read_csv(path, index_col=0)
    if not {"h", "w"}.issubset(df.columns):
        raise ValueError(f"Expected 'h' and 'w' in {path}, got {df.columns.tolist()}")
    return pd.DataFrame({
        "x": df["w"].astype(int),
        "y": df["h"].astype(int),
        "tile_id": df.index if "tile_id" not in df.columns else df["tile_id"].values
    })

def slice_tile(arr, x, y, ts):
    """Slice tile from array given top-left (x,y)."""
    leading = (slice(None),) * (arr.ndim - 2)
    return arr[leading + (slice(y, y+ts), slice(x, x+ts))]

def reduce_to_2d_max_ignore_channel7(tile_nd):
    """Max across all non-spatial dims, but ignore channel index 7 if present."""
    if tile_nd.ndim == 2:
        return tile_nd
    if tile_nd.shape[0] > 7:
        tile_nd = np.delete(tile_nd, 7, axis=0)
    axes = tuple(range(tile_nd.ndim - 2))
    return tile_nd.max(axis=axes)

def compute_tile_coverage(tile2d, min_intensity):
    total = tile2d.size
    present = np.count_nonzero(tile2d > min_intensity)
    return present / total if total > 0 else 0.0

