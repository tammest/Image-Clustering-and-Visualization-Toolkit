# === HELPER: stacked bar with optional log scale on counts + clean legend ===
def stacked_bar_counts(df_counts, title, out_path, xtick_rotation=60, log_y=True,
                       legend_ncol=3, legend_loc="lower center", legend_outside=True):
    """
    df_counts: index = bars (e.g., samples or day groups),
               columns = stack categories (ordered bottom->top),
               values = counts per category.
    """
    fig, ax = plt.subplots(figsize=(max(8, len(df_counts)*0.6), 5))
    bottom = np.zeros(len(df_counts), dtype=float)
    x = np.arange(len(df_counts))

    # Only keep columns that have any counts > 0 to declutter legend
    nonzero_cols = [c for c in df_counts.columns if (df_counts[c].values > 0).any()]
    df_plot = df_counts[nonzero_cols]

    for col in df_plot.columns:
        vals = df_plot[col].values.astype(float)
        ax.bar(x, vals, bottom=bottom, label=col)
        bottom += vals

    if log_y:
        ax.set_yscale("log")
        totals = df_plot.sum(axis=1).values
        if np.any(totals > 0):
            min_pos = np.min(totals[totals > 0])
            ax.set_ylim(bottom=max(1.0, min_pos * 0.5))

    ax.set_xticks(x)
    ax.set_xticklabels(df_counts.index, rotation=xtick_rotation,
                       ha='right' if xtick_rotation else 'center')
    ax.set_ylabel("Tile count" + (" (log scale)" if log_y else ""))
    ax.set_title(title)

    # Cleaner, multi-column legend below the plot
    handles, labels = ax.get_legend_handles_labels()
    if legend_outside:
        ax.legend(handles, labels, title="Coverage bin", ncol=legend_ncol,
                  bbox_to_anchor=(0.5, -0.02), loc=legend_loc,
                  frameon=False, borderaxespad=0.0, columnspacing=1.0, handlelength=1.6)
        plt.tight_layout(rect=[0, 0.08, 1, 1])  # leave room at bottom
    else:
        ax.legend(title="Coverage bin", ncol=legend_ncol, loc=legend_loc, frameon=False)
        plt.tight_layout()

    plt.savefig(out_path, bbox_inches="tight", dpi=150)
    plt.close(fig)
    print(f"Saved stacked bar: {out_path}")

