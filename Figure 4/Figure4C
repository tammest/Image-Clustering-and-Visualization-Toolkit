# --- ROBUST LABEL REGEX (underscores treated as separators) ---
# custom "boundary": not a letter/digit on each side
DAY5_RE  = re.compile(r'(?<![A-Za-z0-9])(day\s*5|pod\s*5|pod5|5d|day5)(?![A-Za-z0-9])', re.I)
DAY10_RE = re.compile(r'(?<![A-Za-z0-9])(day\s*10|pod\s*10|pod10|10d|day10)(?![A-Za-z0-9])', re.I)
GENO_RE  = re.compile(r'(?<![A-Za-z0-9])(wt|dbdb)(?![A-Za-z0-9])', re.I)

def classify_day(name: str) -> str:
    if DAY5_RE.search(name):  return "Day5"
    if DAY10_RE.search(name): return "Day10"
    return "Unknown"

def classify_genotype(name: str) -> str:
    m = GENO_RE.search(name)
    if not m: return "Unknown"
    return "WT" if m.group(1).lower() == "wt" else "dbdb"

